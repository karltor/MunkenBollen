rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regler för de officiella matcherna (Bara Karl får ändra)
    match /matches/{matchId} {
      allow read: if request.auth != null && request.auth.token.email.matches('.*@nyamunken[.]se');
      allow write: if request.auth != null && request.auth.token.email == 'karl.tornered@nyamunken.se';
    }
    
    // NYTT: Regler för användarnas tipsrader
    match /users/{userId}/tips/{tipId} {
      // Alla inloggade kollegor får läsa varandras tips (krävs för leaderboards senare)
      allow read: if request.auth != null && request.auth.token.email.matches('.*@nyamunken[.]se');
      
      // Du får BARA skriva/spara tips på ditt EGET ID (request.auth.uid == userId)
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
  }
}
